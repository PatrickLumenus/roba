{
  "name": "roba",
  "version": "0.0.3",
  "type": "module",
  "types": "./dist/types/src/index.d.ts",
  "private": false,
  "description": "Readable, declaration-first authorization for Typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/PatrickLumenus/roba"
  },
  "author": "PatrickLumenus",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "rba",
    "access control",
    "role based access"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "cypress": "^12.7.0",
    "rollup": "^3.30.0",
    "rollup-plugin-delete": "^2.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "test:open": "pnpm cypress open"
  },
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/esm.mjs",
        "require": "./dist/c.cjs"
      },
      "node": {
        "import": "./dist/esm.mjs",
        "require": "./dist/c.cjs"
      },
      "import": "./dist/esm.mjs",
      "require": "./dist/c.cjs",
      "types": "./dist/types/src/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
